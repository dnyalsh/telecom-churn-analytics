 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["# 📉 Telecom Customer Churn Analytics\n", "**Statistical analysis + ML pipeline** \u2014 chi-squared tests \u2192 logistic regression \u2192 retention strategy\n\n", "**Author:** Danial Shariati | [LinkedIn](https://linkedin.com/in/shariatidanial)\n\n", "---"]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Setup & Imports"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from scipy.stats import chi2_contingency\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import classification_report, confusion_matrix, roc_auc_score, roc_curve\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "plt.rcParams['figure.figsize'] = (10, 6)\n",
    "plt.rcParams['axes.spines.top'] = False\n",
    "plt.rcParams['axes.spines.right'] = False\n",
    "print('Libraries loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Data Loading\n\n", "> **Dataset:** IBM Telco Customer Churn\n", "> Download: https://www.kaggle.com/datasets/blastchar/telco-customer-churn\n", "> Place as `data/telco_churn.csv`"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# df = pd.read_csv('../data/telco_churn.csv')\n",
    "# Reproducible synthetic demo matching Telco dataset structure\n",
    "np.random.seed(42)\n",
    "n = 2000\n",
    "contract = np.random.choice(['Month-to-month','One year','Two year'], n, p=[0.55,0.25,0.20])\n",
    "tenure = np.random.randint(1, 72, n)\n",
    "internet = np.random.choice(['Fiber optic','DSL','No'], n, p=[0.44,0.34,0.22])\n",
    "payment = np.random.choice(['Electronic check','Mailed check','Bank transfer','Credit card'], n, p=[0.34,0.23,0.22,0.21])\n",
    "monthly_charges = np.random.uniform(20, 110, n)\n",
    "churn_prob = (0.05 + 0.25*(contract=='Month-to-month') + 0.10*(payment=='Electronic check')\n",
    "             + 0.08*(internet=='Fiber optic') + 0.15*(tenure<=12) - 0.05*(tenure>48)).clip(0.02, 0.85)\n",
    "df = pd.DataFrame({\n",
    "    'tenure': tenure, 'Contract': contract, 'InternetService': internet,\n",
    "    'PaymentMethod': payment, 'MonthlyCharges': monthly_charges.round(2),\n",
    "    'TotalCharges': (monthly_charges * tenure).round(2),\n",
    "    'Churn': (np.random.random(n) < churn_prob).map({True:'Yes', False:'No'})\n",
    "})\n",
    "print(f'Shape: {df.shape}, Churn rate: {(df.Churn=="Yes").mean():.2%}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. EDA \u2014 Churn Rate by Key Variables"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df['Churned'] = (df['Churn'] == 'Yes').astype(int)\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "cat_vars = ['Contract', 'PaymentMethod', 'InternetService']\n",
    "colors = ['#378ADD', '#E24B4A', '#639922', '#BA7517']\n",
    "for ax, var in zip(axes.flat[:3], cat_vars):\n",
    "    rates = df.groupby(var)['Churned'].mean().sort_values(ascending=False)\n",
    "    bars = ax.bar(rates.index, rates.values, color=colors[:len(rates)], alpha=0.85)\n",
    "    ax.set_title(f'Churn Rate by {var}'); ax.set_ylabel('Churn Rate')\n",
    "    ax.set_xticklabels(rates.index, rotation=15, ha='right')\n",
    "    for bar, val in zip(bars, rates.values):\n",
    "        ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+0.005, f'{val:.1%}', ha='center', fontsize=10)\n",
    "df['tenure_group'] = pd.cut(df['tenure'], bins=[0,12,24,48,72], labels=['0-12','12-24','24-48','48-72'])\n",
    "tenure_churn = df.groupby('tenure_group', observed=True)['Churned'].mean()\n",
    "axes[1,1].bar(tenure_churn.index, tenure_churn.values, color='#534AB7', alpha=0.85)\n",
    "axes[1,1].set_title('Churn Rate by Tenure (months)'); axes[1,1].set_ylabel('Churn Rate')\n",
    "plt.suptitle('Churn Rate by Key Features', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout(); plt.savefig('churn_eda.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Statistical Validation \u2014 Chi-Squared Tests"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('Chi-Squared Tests for Association with Churn')\n",
    "print('=' * 55)\n",
    "print(f\"{'Variable':<22} {'Chi2':>8} {'p-value':>12} {'Significant':>12}\")\n",
    "print('-' * 55)\n",
    "test_vars = ['Contract', 'PaymentMethod', 'InternetService', 'tenure_group']\n",
    "for var in test_vars:\n",
    "    ct = pd.crosstab(df[var], df['Churn'])\n",
    "    chi2, p, dof, _ = chi2_contingency(ct)\n",
    "    sig = '\u2705 YES' if p < 0.05 else '\u274c NO'\n",
    "    print(f'{var:<22} {chi2:>8.2f} {p:>12.4f} {sig:>12}')\n",
    "print('\\nAll 4 variables are statistically significant churn drivers (p < 0.05).')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 5. Logistic Regression Model"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_model = df[['tenure','Contract','InternetService','PaymentMethod','MonthlyCharges','TotalCharges','Churned']].copy()\n",
    "for col in ['Contract','InternetService','PaymentMethod']:\n",
    "    df_model[col] = LabelEncoder().fit_transform(df_model[col])\n",
    "X = df_model.drop(columns=['Churned'])\n",
    "y = df_model['Churned']\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, stratify=y, random_state=42)\n",
    "scaler = StandardScaler()\n",
    "X_train_s = scaler.fit_transform(X_train)\n",
    "X_test_s  = scaler.transform(X_test)\n",
    "lr = LogisticRegression(class_weight='balanced', max_iter=1000, random_state=42)\n",
    "lr.fit(X_train_s, y_train)\n",
    "y_pred = lr.predict(X_test_s)\n",
    "y_prob = lr.predict_proba(X_test_s)[:, 1]\n",
    "auc = roc_auc_score(y_test, y_prob)\n",
    "print(f'ROC AUC: {auc:.3f}\\n')\n",
    "print(classification_report(y_test, y_pred, target_names=['No Churn','Churn']))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 6. ROC Curve & Confusion Matrix"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
    "fpr, tpr, _ = roc_curve(y_test, y_prob)\n",
    "axes[0].plot(fpr, tpr, color='#E24B4A', lw=2, label=f'Logistic Regression (AUC={auc:.3f})')\n",
    "axes[0].plot([0,1],[0,1],'k--', alpha=0.4)\n",
    "axes[0].fill_between(fpr, tpr, alpha=0.1, color='#E24B4A')\n",
    "axes[0].set_xlabel('FPR'); axes[0].set_ylabel('TPR')\n",
    "axes[0].set_title('ROC Curve'); axes[0].legend()\n",
    "cm = confusion_matrix(y_test, y_pred)\n",
    "sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[1],\n",
    "            xticklabels=['No Churn','Churn'], yticklabels=['No Churn','Churn'])\n",
    "axes[1].set_title('Confusion Matrix')\n",
    "axes[1].set_ylabel('Actual'); axes[1].set_xlabel('Predicted')\n",
    "plt.tight_layout(); plt.savefig('roc_confusion.png', dpi=150); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 7. Retention Strategy Recommendations"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "report = classification_report(y_test, y_pred, output_dict=True)\n",
    "recall = report['1']['recall']\n",
    "print('=' * 55)\n",
    "print('RETENTION STRATEGY RECOMMENDATIONS')\n",
    "print('=' * 55)\n",
    "print(f'Model: Logistic Regression | AUC: {auc:.3f} | Recall: {recall:.2%}')\n",
    "print()\n",
    "print('1. CONTRACT TYPE (strongest driver)')\n",
    "print('   Offer discounts to move month-to-month customers to annual plans.')\n",
    "print()\n",
    "print('2. PAYMENT METHOD')\n",
    "print('   Incentivise autopay (bank transfer / credit card) for e-check users.')\n",
    "print()\n",
    "print('3. INTERNET SERVICE')\n",
    "print('   Fibre optic customers churn despite premium price.')\n",
    "print('   Improve service quality or offer a satisfaction SLA.')\n",
    "print()\n",
    "print('4. TENURE (first 12 months = highest risk)')\n",
    "print('   Proactive onboarding + check-in survey at month 6.')"
   ]
  }
 ]
}
